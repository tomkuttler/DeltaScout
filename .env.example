# Gmail account used as SMTP sender
GMAIL_SMTP_USER=your.account@gmail.com

# Gmail app password (requires Google account 2FA)
GMAIL_APP_PASSWORD=your-16-char-app-password

# Alert recipient(s). Single recipient expected, comma-separated list also supported.
ALERT_EMAIL_TO=recipient@example.com

# Optional overrides
REQUEST_TIMEOUT_SECONDS=15
USER_AGENT=DeltaScout/1.0
